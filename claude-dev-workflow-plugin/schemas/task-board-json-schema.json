{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "task-board-json-schema.json",
  "title": "task-board.json",
  "description": "Task DAG and metadata for development phase",
  "type": "object",
  "required": ["tasks", "dag"],
  "properties": {
    "tasks": {
      "type": "array",
      "items": { "$ref": "#/definitions/task" }
    },
    "dag": {
      "type": "object",
      "properties": {
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from", "to"],
            "properties": {
              "from": { "type": "string" },
              "to": { "type": "string" }
            }
          }
        }
      },
      "additionalProperties": false
    }
  },
  "definitions": {
    "task": {
      "type": "object",
      "required": ["id", "title", "description", "dependsOn", "status", "priority", "complexity", "modelTier", "files", "acceptanceCriteria", "tddRounds"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "dependsOn": {
          "type": "array",
          "items": { "type": "string" }
        },
        "status": {
          "type": "string",
          "enum": ["todo", "dispatched", "in_progress", "review_pending", "done", "failed", "blocked", "environment_blocked"]
        },
        "priority": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        },
        "complexity": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "modelTier": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "assignedBranch": { "type": "string" },
        "parallelGroup": { "type": "string" },
        "files": {
          "type": "object",
          "properties": {
            "create": { "type": "array", "items": { "type": "string" } },
            "modify": { "type": "array", "items": { "type": "string" } },
            "read": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": false
        },
        "acceptanceCriteria": {
          "type": "object",
          "properties": {
            "featureRef": { "type": "string" },
            "taskLevel": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": false
        },
        "interfaceRef": { "type": "string" },
        "tddRounds": {
          "type": "integer",
          "minimum": 0
        },
        "lastFailure": {
          "type": ["object", "null"],
          "properties": {
            "round": { "type": "integer" },
            "failureReason": { "type": "string" },
            "reviewComments": { "type": "array", "items": { "type": "string" } },
            "failingTests": { "type": "array", "items": { "type": "string" } },
            "errorLogs": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  }
}
